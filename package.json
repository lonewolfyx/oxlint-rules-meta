{
    "name": "oxlint-rules-meta",
    "type": "module",
    "version": "0.0.3",
    "packageManager": "pnpm@10.30.3",
    "description": "Metadata and JSON data for all Oxlint rules.",
    "author": "lonewolfyx",
    "license": "MIT",
    "homepage": "https://github.com/lonewolfyx/oxlint-rules-meta#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lonewolfyx/oxlint-rules-meta.git"
    },
    "bugs": "https://github.com/lonewolfyx/oxlint-rules-meta/issues",
    "keywords": [
        "oxlint",
        "rules",
        "metadata",
        "rules-config"
    ],
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "tsx watch ./src/oxlint-rules-meta.ts",
        "dev:build": "tsdown --watch",
        "build": "tsdown",
        "release": "npm publish",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prepublishOnly": "pnpm build",
        "prepare": "simple-git-hooks",
        "oxc-website": "giget gh:oxc-project/website"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.7.0",
        "@lonewolfyx/tsconfig": "^0.0.6",
        "@next/eslint-plugin-next": "^16.1.6",
        "@types/eslint-plugin-jsx-a11y": "^6.10.1",
        "@types/json-schema": "^7.0.15",
        "@types/node": "^25.3.5",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "cheerio": "^1.2.0",
        "eslint": "^9.39.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-jsdoc": "^62.7.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-perf": "^3.3.3",
        "eslint-plugin-unicorn": "^63.0.0",
        "eslint-plugin-vitest": "^0.5.4",
        "eslint-plugin-vue": "^10.8.0",
        "genson-js": "^0.0.8",
        "giget": "^3.1.2",
        "jiti": "^2.6.1",
        "json-schema": "^0.4.0",
        "lint-staged": "^16.3.2",
        "marked": "^17.0.4",
        "oxlint": "^1.51.0",
        "picocolors": "^1.1.1",
        "simple-git-hooks": "^2.13.1",
        "tinyexec": "^1.0.2",
        "tsdown": "^0.21.0",
        "tsdown-preset": "^1.0.5",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
